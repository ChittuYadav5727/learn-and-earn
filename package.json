{
  "name": "learn-and-earn-workspace",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "server:dev": "npm --prefix server run dev",
    "server:start": "npm --prefix server run start",
    "server:seed": "npm --prefix server run seed"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
